<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light dark">
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#FAFAF8">
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0E0E0D">
  <meta name="generator" content="pandoc">
  <meta property="og:type" content="website">
  $for(author-meta)$
  <meta name="author" content="$author-meta$">
  $endfor$
  $if(date-meta)$
  <meta name="date" content="$date-meta$">
  $endif$
  $if(keywords)$
  <meta name="keywords" content="$for(keywords)$$keywords$$sep$, $endfor$">
  $endif$
  $if(description-meta)$
  <meta name="description" content="$description-meta$">
  <meta property="og:description" content="$description-meta$">
  $endif$
  <title>$if(title-prefix)$$title-prefix$ – $endif$$pagetitle$</title>
  $if(title-prefix)$<meta property="og:site_name" content="$title-prefix$">$endif$
  <meta property="og:title" content="$pagetitle$">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <link rel="stylesheet" href="academicons/css/academicons.min.css">
  $for(css)$
  <link rel="stylesheet" href="$css$">
  $endfor$
  $if(og-picture)$
  <meta property="og:image" content="$og-picture$">
  $endif$
  $if(og-url)$
  <meta property="og:url" content="$og-url$">
  $endif$
  $for(header-includes)$
  $header-includes$
  $endfor$
  $if(math)$
  $if(mathjax)$
  <script src="https://polyfill.io/v3/polyfill.min.js?features=es6"></script>
  $endif$
  $math$
  $endif$
  <link rel="icon" type="image/png" href="/img/orob.png">
  <link rel="shortcut icon" href="/img/orob.png">
  <link rel="apple-touch-icon" href="/img/orob.png">
</head>
<body>

  <header>
    <div class="header-left">
      $if(picture)$
        $if(picture-round)$
        <img class="portrait round" src="$picture$" alt="$author$">
        $else$
        <img class="portrait" src="$picture$" alt="$author$">
        $endif$
      $endif$
      <div class="header-identity">
        $if(author)$
        <h1>$author$</h1>
        $endif$
        $if(shortbio)$
        <p class="tagline">$shortbio$</p>
        $endif$
      </div>
    </div>
    <div class="header-right">
      $if(email)$
      <p class="contact"><i class="fa-regular fa-envelope fa-fw"></i> <code>$email$</code></p>
      $endif$
      $if(location)$
      <p class="contact"><i class="fa-solid fa-location-dot fa-fw"></i> $location$</p>
      $endif$
      <div class="icons">
        $if(cv)$
        <a href="$cv$" aria-label="CV"><i class="ai ai-cv"></i></a>
        $endif$
        $if(orcid)$
        <a href="https://orcid.org/$orcid$" aria-label="ORCID"><i class="ai ai-orcid"></i></a>
        $endif$
        $if(dblp)$
        <a href="$dblp$" aria-label="DBLP"><i class="ai ai-dblp"></i></a>
        $endif$
        $if(hal)$
        <a href="$hal$" aria-label="HAL"><i class="ai ai-hal"></i></a>
        $endif$
        $if(scholar)$
        <a href="$scholar$" aria-label="Google Scholar"><i class="ai ai-google-scholar"></i></a>
        $endif$
        $if(github)$
        <a href="https://github.com/$github$" aria-label="GitHub"><i class="fa-brands fa-github"></i></a>
        $endif$
        $if(gitlab)$
        <a href="https://gitlab.com/$gitlab$" aria-label="GitLab"><i class="fa-brands fa-gitlab"></i></a>
        $endif$
        $if(bitbucket)$
        <a href="$bitbucket$" aria-label="BitBucket"><i class="fa-brands fa-bitbucket"></i></a>
        $endif$
        $if(mastodon)$
        <a href="$mastodon$" aria-label="Mastodon"><i class="fa-brands fa-mastodon"></i></a>
        $endif$
        $if(bluesky)$
        <a href="$bluesky$" aria-label="BlueSky"><i class="fa-brands fa-bluesky"></i></a>
        $endif$
        $if(linkedin)$
        <a href="$linkedin$" aria-label="LinkedIn"><i class="fa-brands fa-linkedin"></i></a>
        $endif$
      </div>
    </div>
  </header>

  $if(toc)$
  <nav aria-label="Section navigation">
    $table-of-contents$
  </nav>
  $endif$

  <main>
    $for(include-before)$
    $include-before$
    $endfor$
    $body$
    $for(include-after)$
    $include-after$
    $endfor$
  </main>

  $if(footer)$
  <footer>
    $footer$
    <span class="lastupdate">Last updated: $date$</span>
  </footer>
  $endif$

</body>
</html>
